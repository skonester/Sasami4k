<Window xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"  x:Class="WinView2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinView2"
        mc:Ignorable="d"
        Background="Black"
        AllowsTransparency="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        BorderThickness="0"
        Title="Sasami4K" Height="450" Width="800"
        Icon="resources/winview2.ico">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Wpf:WebView2 x:Name="webView" DefaultBackgroundColor="Transparent" />
    </Grid>
</Window>